# G-A-COWORK Environment Variables
# Copy this file to .env and fill in your actual API keys

# ─── Required ──────────────────────────────────────────────
# Google Gemini API Key (get from: https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Optional ──────────────────────────────────────────────
# Tavily API Key for real web search (get from: https://tavily.com)
# Without this, web_search tool will return a placeholder message
TAVILY_API_KEY=your_tavily_api_key_here

# Telegram Bot (for remote HITL approvals)
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Backend port (default: 3000)
PORT=3000

# Workspace directory path inside the container
WORKSPACE_PATH=/workspace
